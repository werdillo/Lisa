---
import "../styles/global.css";
import { Footer } from "./footer";
import { LpNavbar } from "./navbar";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <link
            rel="icon"
            type="image/png"
            href="/favicon-96x96.png"
            sizes="96x96"
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="shortcut icon" href="/favicon.ico" />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/apple-touch-icon.png"
        />
        <link rel="manifest" href="/site.webmanifest" />
        <title>Lisa Custom Tattoo Artist in Riga, Latvia</title>
        <meta
            name="description"
            content="Professional female tattoo artist based in a premium Riga studio. Specializing in custom designs, from fine line to graphic styles. View my extensive portfolio and book your private session today."
        />
    </head>
    <body class="dark">
        <LpNavbar client:load />
        <slot />
        <Footer />
    </body>
</html>
