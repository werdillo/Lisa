---
import "../styles/global.css";
// Component Imports
import Main from "@/layouts/main.astro";
import HeroSection from "@/components/hero-section";
import { FeatureSection } from "@/components/feature-section";
import { BentoGrid } from "@/components/bento-grid";
import { ContactSection } from "@/components/contact-section";
import { Image } from "astro:assets";
---

<Main>
    <div class="flex flex-col gap-24 lg:gap-60 mb-24 lg:mb-60">
        <HeroSection />
        <div id="about" class="scroll-mt-24 lg:scroll-mt-60">
            <FeatureSection />
        </div>
        <div id="portfolio" class="scroll-mt-24 lg:scroll-mt-60">
            <BentoGrid client:load />
        </div>
        <div id="contacts" class="scroll-mt-24 lg:scroll-mt-60">
            <ContactSection client:load />
        </div>
        <div
            class="flex flex-col justify-center items-center gap-6 px-6 md:px-0"
        >
            <Image
                src="/assets/sertificate.jpg"
                alt="Professional hygiene and sanitary safety certificate for tattoo artist Jelisaveta Murzajeva in Riga, Latvia. Certification in workplace disinfection, tool sterilization, and medical-grade hygiene standards for tattooing."
                height={320}
                width={256}
                inferSize={true}
            />
            <h1 class="uppercase max-w-3xl text-center">
                A Certified Tattoo Artist's Promise -  Your Vision, My Expertise
            </h1>
        </div>
    </div>
</Main>
